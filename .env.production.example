# Production Environment Configuration
# IMPORTANT: Never commit actual secrets to version control.
# Use this as a template and populate with real values from Neon Cloud.

# Server Configuration
NODE_ENV=production
PORT=3000
APP_PORT=3000
LOG_LEVEL=warn

# Database Configuration - Neon Cloud
# Get this from your Neon Cloud dashboard
# Format: postgres://[user]:[password]@[project-id].neon.tech/[database]?sslmode=require
DATABASE_URL=postgres://user:password@ep-xxxxxx.neon.tech/dbname?sslmode=require

# CORS and Security
# Set to your actual production domain
CORS_ORIGIN=https://yourdomain.com

# JWT Secret - Generate a secure random token
# Example (DO NOT USE): generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-very-secure-random-jwt-secret-here

# Arcjet Configuration (if using)
# ARCJET_KEY=your_arcjet_production_key

# Optional: Connection pool settings for Neon Cloud
# DATABASE_POOL_MIN=2
# DATABASE_POOL_MAX=10
